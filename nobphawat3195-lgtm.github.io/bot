function addMemory(trade) {
  S.memory.unshift(trade);
  if(S.memory.length>200) S.memory.pop();
  localStorage.setItem('afx_memory',JSON.stringify(S.memory));
  renderMemory();
  updatePerformance();
}

function renderMemory() {
  const list=document.getElementById('memoryList');
  const count=document.getElementById('memCount');
  const prMem=document.getElementById('pr-mem');
  count.textContent=S.memory.length+' trades';
  prMem.textContent=S.memory.length+' trades stored';
  if(!S.memory.length){ list.innerHTML='<div class="empty">ยังไม่มีข้อมูล Memory</div>'; return; }
  list.innerHTML=S.memory.slice(0,20).map(t=>`
    <div class="mem-row">
      <div class="mem-left">
        <div class="mem-pair">${t.pair} · ${t.type==='buy'?'▲ BUY':'▼ SELL'} ${t.lot}</div>
        <div class="mem-reason">${t.reason||'—'}</div>
      </div>
      <div class="mem-right">
        <div class="mem-pnl ${(t.pnl||0)>=0?'p':'n'}">${(t.pnl||0)>=0?'+':''}$${(t.pnl||0).toFixed(2)}</div>
        <div class="mem-conf">Conf: ${t.conf||0}%</div>
      </div>
    </div>`).join('');

  const histBody=document.getElementById('historyBody');
  histBody.innerHTML=S.memory.slice(0,20).map(t=>`
    <tr>
      <td style="font-size:9px;color:var(--text3)">${t.time||'—'}</td>
      <td class="t-sym">${t.pair}</td>
      <td>${t.type==='buy'?'<span class="t-buy">BUY</span>':'<span class="t-sell">SELL</span>'}</td>
      <td class="${(t.pnl||0)>=0?'t-pnl-p':'t-pnl-n'}">${(t.pnl||0)>=0?'+':''}$${(t.pnl||0).toFixed(2)}</td>
      <td style="font-size:9px;color:var(--text2)">${(t.reason||'').substring(0,20)}...</td>
    </tr>`).join('');
}

function updatePerformance() {
  const mem=S.memory;
  if(!mem.length) return;
  const wins=mem.filter(t=>(t.pnl||0)>0).length;
  const wr=Math.round((wins/mem.length)*100);
  const tpnl=mem.reduce((s,t)=>s+(t.pnl||0),0);
  const avg=tpnl/mem.length;
  const best=Math.max(...mem.map(t=>t.pnl||0));
  const worst=Math.min(...mem.map(t=>t.pnl||0));
  document.getElementById('p-wr').textContent=wr+'%';
  document.getElementById('p-total').textContent=mem.length;
  document.getElementById('p-tpnl').textContent=(tpnl>=0?'+':'')+'$'+tpnl.toFixed(2);
  document.getElementById('p-avg').textContent=(avg>=0?'+':'')+'$'+avg.toFixed(2);
  document.getElementById('p-best').textContent='+$'+best.toFixed(2);
  document.getElementById('p-worst').textContent='$'+worst.toFixed(2);
  document.getElementById('d-wr').textContent=wr+'%';
}

