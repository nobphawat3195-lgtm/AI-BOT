// LOAD POSITIONS
// ═══════════════════════════════════════════════
async function loadPositions() {
  if(!S.connected) return;
  try {
    const pos=await apiGet(`/users/current/accounts/${S.accId}/positions`,S.token);
    S.positions=pos;
    renderOpenPositions(pos);
    renderRecentTrades(pos);
    document.getElementById('d-open').textContent=pos.length;
    const lots=pos.reduce((s,p)=>s+(p.volume||0),0);
    document.getElementById('d-lots').textContent=lots.toFixed(2)+' lots';
    const fpnl=pos.reduce((s,p)=>s+(p.profit||0),0);
    document.getElementById('t-fpnl').textContent=(fpnl>=0?'+':'')+'$'+fpnl.toFixed(2);
    document.getElementById('t-fpnl').style.color=fpnl>=0?'var(--green)':'var(--red)';
    document.getElementById('t-openpos').textContent=pos.length;
    document.getElementById('d-pnl').textContent=(fpnl>=0?'+':'')+'$'+fpnl.toFixed(2);
    document.getElementById('d-pnl').className='sv '+(fpnl>=0?'g':'r');
    log('Positions loaded: '+pos.length+' open','lg');
  } catch(e) { log('Position error: '+e.message,'lr'); }
}

function renderOpenPositions(pos) {
  const tbody=document.getElementById('openPositionsBody');
  if(!pos.length){ tbody.innerHTML='<tr><td colspan="5" class="empty">No open positions</td></tr>'; return; }
  tbody.innerHTML=pos.map(p=>{
    const pnl=p.profit||0;
    const isPos=pnl>=0;
    const side=p.type==='POSITION_TYPE_BUY'?'<span class="t-buy">▲ BUY</span>':'<span class="t-sell">▼ SELL</span>';
    return `<tr>
      <td class="t-sym">${p.symbol||'—'}</td>
      <td>${side}</td>
      <td>${(p.volume||0).toFixed(2)}</td>
      <td>${(p.openPrice||0).toFixed(5)}</td>
      <td class="${isPos?'t-pnl-p':'t-pnl-n'}">${isPos?'+':''}$${pnl.toFixed(2)}</td>
    </tr>`;
  }).join('');
}

function renderRecentTrades(pos) {
  const tbody=document.getElementById('recentTradesBody');
  if(!pos.length){ tbody.innerHTML='<tr><td colspan="4" class="empty">No trades</td></tr>'; return; }
  tbody.innerHTML=pos.slice(0,5).map(p=>{
    const pnl=p.profit||0;
    const isPos=pnl>=0;
    const side=p.type==='POSITION_TYPE_BUY'?'<span class="t-buy">BUY</span>':'<span class="t-sell">SELL</span>';
    return `<tr>
      <td class="t-sym">${p.symbol||'—'}</td>
      <td>${side}</td>
      <td>${(p.volume||0).toFixed(2)}</td>
      <td class="${isPos?'t-pnl-p':'t-pnl-n'}">${isPos?'+':''}$${pnl.toFixed(2)}</td>
    </tr>`;
  }).join('');
  document.getElementById('d-total').textContent=pos.length;
}

// ═══════════════════════════════════════════════
// PLACE ORDER
// ═══════════════════════════════════════════════
async function placeOrder() {
  if(!S.connected){showMsg('order-err','ยังไม่ได้เชื่อมต่อ MT5');return;}
  const sym=document.getElementById('m-pair').value;
  const dir=document.getElementById('m-dir').value;
  const lot=parseFloat(document.getElementById('m-lot').value)||0;
  const sl=parseFloat(document.getElementById('m-sl').value)||0;
  if(lot<=0){showMsg('order-err','✕ Lot size ไม่ถูกต้อง');return;}
  hideMsg('order-err');hideMsg('order-ok');
  const btn=document.getElementById('placeBtn');
  btn.disabled=true;btn.innerHTML='<div class="spin"></div> PLACING...';
  const dirLabel=dir==='ORDER_TYPE_BUY'?'BUY':'SELL';
  log(`Manual order: ${dirLabel} ${lot} ${sym}`,'la');
  try {
    const body={symbol:sym,volume:lot,actionType:dir,comment:'AI-BOT-Manual'};
    if(sl>0) body.stopLoss=sl;
    const res=await apiPost(`/users/current/accounts/${S.accId}/trade`,S.token,body);
    const id=res.orderId||res.positionId||'—';
    showMsg('order-ok',`✓ ${dirLabel} ${lot} ${sym} · ID: ${id}`);
    log(`Order OK: #${id}`,'lg');
    await loadPositions();
  } catch(e) {
    showMsg('order-err','✕ '+friendlyErr(e.message));
    log('Order failed: '+e.message,'lr');
  } finally {
    btn.disabled=false;btn.innerHTML='▲ PLACE MANUAL ORDER';
  }
}

async function closeAll() {
  if(!S.connected||!S.positions.length) return;
  log('Closing all '+S.positions.length+' positions...','la');
  let ok=0,fail=0;
  for(const p of S.positions) {
    try {
      await apiPost(`/users/current/accounts/${S.accId}/trade`,S.token,{actionType:'POSITION_CLOSE_ID',positionId:p.id});
      ok++;
    } catch{fail++;}
  }
  showMsg('order-ok',`ปิดสำเร็จ ${ok} · ล้มเหลว ${fail}`);
  log(`Close all: ${ok} OK, ${fail} failed`,ok>0?'lg':'lr');
  await loadPositions();
}

