// ═══════════════════════════════════════════════
// API
// ═══════════════════════════════════════════════
async function apiGet(path,token) {
  const r=await fetch(API+path,{headers:{'auth-token':token}});
  const d=await r.json();
  if(!r.ok) throw new Error(d.message||d.error||'HTTP '+r.status);
  return d;
}
async function apiPost(path,token,body) {
  const r=await fetch(API+path,{method:'POST',headers:{'auth-token':token,'Content-Type':'application/json'},body:JSON.stringify(body)});
  const d=await r.json();
  if(!r.ok) throw new Error(d.message||d.error||'HTTP '+r.status);
  return d;
}
function friendlyErr(msg) {
  if(!msg) return 'Unknown error';
  if(msg.includes('401')||msg.toLowerCase().includes('unauthorized')) return 'Token ไม่ถูกต้อง';
  if(msg.includes('404')||msg.toLowerCase().includes('not found')) return 'ไม่พบ Account ID';
  if(msg.includes('403')) return 'ไม่มีสิทธิ์เข้าถึง';
  if(msg.toLowerCase().includes('failed to fetch')) return 'ไม่มี internet · ตรวจสอบ WiFi/4G';
  return msg;
}

