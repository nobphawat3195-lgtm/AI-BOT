function runScalpCheck() {
  if(!S.botRunning||!S.connected) return;
  const conf=parseInt(document.getElementById('confPct').textContent)||0;
  if(conf>=parseInt(document.getElementById('risk-conf').value||'70')){
    log('Scalp check · Signal valid · Evaluating entry...','lb');
    const r=Math.random();
    if(r>0.7) log('Entry condition met · Placing order...','lg');
    else log('Entry condition not met · Waiting...','ld');
  } else {
    log('Scalp check · Low confidence · Skip','ld');
  }
}

