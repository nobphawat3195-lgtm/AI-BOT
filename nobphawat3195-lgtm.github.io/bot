<script>
// ═══════════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════════
const S = {
  token: localStorage.getItem('afx_token')||'',
  accId: localStorage.getItem('afx_accid')||'',
  aiKey: localStorage.getItem('afx_aikey')||'',
  aiModel: localStorage.getItem('afx_aimodel')||'gpt',
  connected: false,
  botRunning: false,
  botStart: null,
  info: null,
  positions: [],
  memory: JSON.parse(localStorage.getItem('afx_memory')||'[]'),
  settings: JSON.parse(localStorage.getItem('afx_settings')||'{}'),
  refreshTimer: null,
  aiTimer: null,
  scalpTimer: null,
  selectedPairs: JSON.parse(localStorage.getItem('afx_pairs')||'["EURUSD","EURAUD","XAUUSD"]'),
  uptime: 0,
  uptimeTimer: null,
};

const API = 'https://mt-client-api-v1.london.agiliumtrade.ai';
const PAIRS_ALL = ['EURUSD','EURAUD','GBPUSD','USDJPY','XAUUSD','GBPJPY','AUDUSD','USDCAD','NZDUSD','EURGBP','EURJPY','USDCHF','BTCUSD','ETHUSD'];

// ═══════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════
window.onload = () => {
  setTimeout(()=>{
    const s=document.getElementById('splash');
    s.style.transition='opacity .6s';s.style.opacity='0';
    setTimeout(()=>s.remove(),600);
  },2200);

  log('AI Trading Bot v4.0 initialized','ld');
  log('Scalping Engine + AI Manager ready','lb');

  buildPairGrid();
  renderMemory();
  updatePerformance();

  if(S.token) document.getElementById('inp-token').value=S.token;
  if(S.accId) document.getElementById('inp-accid').value=S.accId;
  if(S.aiKey) document.getElementById('inp-aikey').value=S.aiKey;
  selectAIModel(S.aiModel);
  chkSetup();

  if(S.token&&S.accId) {
    log('Saved credentials found · Auto-connecting...','lb');
    doConnect();
  } else {
    log('No credentials · Go to AI & API tab','la');
  }
};

// ═══════════════════════════════════════════════
// NAVIGATION
// ═══════════════════════════════════════════════
function go(tab) {
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('on'));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('on'));
  const ni = document.getElementById('nav-'+tab);
  const pg = document.getElementById('page-'+tab);
  if(ni) ni.classList.add('on');
  if(pg) pg.classList.add('on');
  document.querySelector('.main').scrollTop=0;
}

// ═══════════════════════════════════════════════
// AI MODEL
// ═══════════════════════════════════════════════
function selectAI(model, el) {
  document.querySelectorAll('.ai-btn').forEach(b=>b.classList.remove('selected'));
  el.classList.add('selected');
  S.aiModel = model;
  localStorage.setItem('afx_aimodel',model);
  const names = {claude:'Claude (Anthropic)',gpt:'GPT-4o (OpenAI)',gemini:'Gemini (Google)',grok:'Grok (xAI)'};
  document.getElementById('s-model').textContent = names[model]||model;
  document.getElementById('pr-ai').textContent = names[model]||model;
  log('AI Model selected: '+names[model],'lp');

  const ph = {claude:'sk-ant-...', gpt:'sk-...', gemini:'AIza...', grok:'xai-...'};
  document.getElementById('inp-aikey').placeholder = ph[model]||'API Key...';
}

function selectAIModel(model) {
  const btn = document.querySelector('.ai-btn.'+model);
  if(btn) selectAI(model,btn);
}

// ═══════════════════════════════════════════════
// PAIR GRID
// ═══════════════════════════════════════════════
function buildPairGrid() {
  const grid = document.getElementById('pairGrid');
  grid.innerHTML = PAIRS_ALL.map(p=>`
    <div onclick="togglePair('${p}',this)"
      style="padding:8px 4px;border-radius:8px;border:1px solid ${S.selectedPairs.includes(p)?'rgba(30,111,255,.4)':'var(--border2)'};
      background:${S.selectedPairs.includes(p)?'rgba(30,111,255,.12)':'rgba(3,6,15,.5)'};
      text-align:center;cursor:pointer;font-size:10px;font-weight:700;
      color:${S.selectedPairs.includes(p)?'var(--blue2)':'var(--text3)'};transition:all .2s">
      ${p}
    </div>`).join('');
}

function togglePair(pair, el) {
  const idx = S.selectedPairs.indexOf(pair);
  if(idx>-1) S.selectedPairs.splice(idx,1);
  else S.selectedPairs.push(pair);
  localStorage.setItem('afx_pairs',JSON.stringify(S.selectedPairs));
  buildPairGrid();
  document.getElementById('s-pairs').textContent = S.selectedPairs.join(', ')||'—';
}

// ═══════════════════════════════════════════════
// VALIDATE
// ═══════════════════════════════════════════════
function chkSetup() {
  const t=document.getElementById('inp-token').value.trim();
  const a=document.getElementById('inp-accid').value.trim();
  const k=document.getElementById('inp-aikey').value.trim();
  const btn=document.getElementById('btn-conn');
  btn.disabled=!(t.length>10&&a.length>5);

  // Update steps
  if(k.length>10){
    document.getElementById('step1').classList.add('done');
    document.getElementById('step1').classList.remove('active');
    document.getElementById('step2').classList.add('active');
  }
  if(t.length>10&&a.length>5){
    document.getElementById('step2').classList.add('done');
    document.getElementById('step2').classList.remove('active');
    document.getElementById('step3').classList.add('active');
  }
}

// ═══════════════════════════════════════════════
// CONNECT
// ═══════════════════════════════════════════════
async function doConnect() {
  const token=document.getElementById('inp-token').value.trim();
  const accId=document.getElementById('inp-accid').value.trim();
  const aiKey=document.getElementById('inp-aikey').value.trim();
  if(!token||!accId) return;

  S.token=token; S.accId=accId; S.aiKey=aiKey;
  hideMsg('conn-err'); hideMsg('conn-ok');
  const btn=document.getElementById('btn-conn');
  btn.disabled=true;
  btn.innerHTML='<div class="spin"></div> CONNECTING...';
  log('Connecting to MetaAPI...','lb');
  setBotPill('loading');

  try {
    const info = await apiGet(`/users/current/accounts/${accId}/account-information`,token);
    S.info=info; S.connected=true;
    localStorage.setItem('afx_token',token);
    localStorage.setItem('afx_accid',accId);
    localStorage.setItem('afx_aikey',aiKey);

    updateProfile(info);
    updateDashNumbers(info);
    showMsg('conn-ok','✓ เชื่อมต่อสำเร็จ! '+( info.broker||'')+ ' · '+(info.server||''));
    document.getElementById('connBadgeSm').textContent='✓ Connected';
    document.getElementById('connBadgeSm').style.color='var(--green)';
    document.getElementById('btn-disc').style.display='flex';
    document.getElementById('step3').classList.add('done');
    document.getElementById('step3').classList.remove('active');
    document.getElementById('dash-empty').style.display='none';
    document.getElementById('dash-live').style.display='flex';
    document.getElementById('s-pairs').textContent=S.selectedPairs.join(', ');
    document.getElementById('s-model').textContent=S.aiModel.toUpperCase();
    setBotPill('stopped');

    log('Connected: '+(info.broker||'Broker')+' · '+(info.server||''),'lg');
    log('Balance: $'+(info.balance||0).toFixed(2)+' · Equity: $'+(info.equity||0).toFixed(2),'lg');
    log('Leverage: 1:'+(info.leverage||0)+' · Currency: '+(info.currency||'USD'),'lb');

    await loadPositions();
    renderChart();
    startAutoRefresh();

  } catch(e) {
    S.connected=false;
    setBotPill('stopped');
    showMsg('conn-err','✕ '+friendlyErr(e.message));
    log('Connection failed: '+e.message,'lr');
    btn.disabled=false;
    btn.innerHTML='🔌 TEST CONNECTION';
  }
}

function doDisconnect() {
  S.connected=false; S.botRunning=false; S.info=null; S.positions=[];
  clearInterval(S.refreshTimer); clearInterval(S.aiTimer);
  clearInterval(S.scalpTimer); clearInterval(S.uptimeTimer);
  localStorage.removeItem('afx_token'); localStorage.removeItem('afx_accid');
  ['inp-token','inp-accid'].forEach(id=>document.getElementById(id).value='');
  chkSetup(); setBotPill('stopped');
  document.getElementById('btn-disc').style.display='none';
  document.getElementById('dash-empty').style.display='flex';
  document.getElementById('dash-live').style.display='none';
  document.getElementById('connBadgeSm').textContent='Not connected';
  document.getElementById('connBadgeSm').style.color='';
  hideMsg('conn-ok');
  document.getElementById('btn-conn').disabled=true;
  document.getElementById('btn-conn').innerHTML='🔌 TEST CONNECTION';
  log('Disconnected · All credentials cleared','la');
}

// ═══════════════════════════════════════════════
// BOT TOGGLE
// ═══════════════════════════════════════════════
function toggleBot() {
  if(!S.connected){go('aiapi');return;}
  S.botRunning=!S.botRunning;
  if(S.botRunning){
    S.botStart=new Date();
    setBotPill('running');
    document.getElementById('s-status').textContent='Running';
    document.getElementById('s-status').style.color='var(--green)';
    document.getElementById('startBtn').className='btn btn-red btn-full';
    document.getElementById('startBtn').textContent='⏹ STOP BOT';
    document.getElementById('botBtn').className='btn btn-red btn-full';
    startUptimeTimer();
    startAIAnalysis();
    log('Bot STARTED · Scalping mode active','lg');
    log('AI Manager will analyze every 60min','lb');
    log('Scalp Engine checking every 1min','lb');
    simulateAIInsight();
  } else {
    setBotPill('stopped');
    document.getElementById('s-status').textContent='Stopped';
    document.getElementById('s-status').style.color='var(--red)';
    document.getElementById('startBtn').className='btn btn-green btn-full';
    document.getElementById('startBtn').textContent='▶ START BOT';
    document.getElementById('botBtn').className='btn btn-green btn-full';
    clearInterval(S.aiTimer); clearInterval(S.scalpTimer); clearInterval(S.uptimeTimer);
    document.getElementById('s-nextai').textContent='—';
    document.getElementById('s-nextscalp').textContent='—';
    log('Bot STOPPED by user','la');
  }
}

function setBotPill(state) {
  const pill=document.getElementById('botPill');
  const dot=document.getElementById('botDot');
  const txt=document.getElementById('botPillTxt');
  pill.className='bot-pill '+state;
  if(state==='running'){dot.className='pill-dot g';txt.textContent='BOT RUNNING';}
  else if(state==='loading'){dot.className='pill-dot a';txt.textContent='CONNECTING...';}
  else{dot.className='pill-dot r';txt.textContent='BOT STOPPED';}
}

// ═══════════════════════════════════════════════
// TIMERS
// ═══════════════════════════════════════════════
function startUptimeTimer() {
  clearInterval(S.uptimeTimer);
  S.uptime=0;
  S.uptimeTimer=setInterval(()=>{
    S.uptime++;
    const h=Math.floor(S.uptime/3600);
    const m=Math.floor((S.uptime%3600)/60);
    const s=S.uptime%60;
    document.getElementById('s-uptime').textContent=`${pad(h)}h ${pad(m)}m ${pad(s)}s`;
  },1000);
}

let aiCountdown=3600, scalpCountdown=60;
function startAIAnalysis() {
  clearInterval(S.aiTimer); clearInterval(S.scalpTimer);
  aiCountdown=3600; scalpCountdown=60;

  S.aiTimer=setInterval(()=>{
    aiCountdown--;
    const m=Math.floor(aiCountdown/60),sc=aiCountdown%60;
    document.getElementById('s-nextai').textContent=`${pad(m)}:${pad(sc)}`;
    if(aiCountdown<=0){ aiCountdown=3600; simulateAIInsight(); }
  },1000);

  S.scalpTimer=setInterval(()=>{
    scalpCountdown--;
    const m=Math.floor(scalpCountdown/60),sc=scalpCountdown%60;
    document.getElementById('s-nextscalp').textContent=`${pad(m)}:${pad(sc)}`;
    if(scalpCountdown<=0){ scalpCountdown=60; runScalpCheck(); }
  },1000);
}

